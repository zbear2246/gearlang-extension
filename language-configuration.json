{
    "autoClosingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"],
        ["\"", "\""]
    ],
    "brackets": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"]
    ],
    "comments": {
        "blockComment": ["/*", "*/"],
        "lineComment": {
            "comment": "//"
        }
    },
    "indentationRules": {
        "decreaseIndentPattern": "^\\s*\\}\\s*$",
        "increaseIndentPattern": "^\\s*\\{\\s*$"
    },
    "onEnterRules": [
        {
            "action": {
                "indent": "indent"
            },
            "beforeText": ":\\s*$"
        }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["[", "]"],
        ["{", "}"],
        ["\"", "\""]
    ]
}
